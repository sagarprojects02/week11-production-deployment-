# src/app.py
from flask import Flask, jsonify
import os

def create_app():
    app = Flask(__name__)
    app.config.from_object(f"config.{os.getenv('ENV', 'development')}")

    @app.route("/")
    def home():
        return jsonify({"message": "App is running!"})

    @app.route("/health")
    def health():
        return jsonify({"status": "OK"})

    return app

app = create_app()

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
